<Window x:Class="TileBasedLevelEditor.Views.NewTilemapDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TileBasedLevelEditor.Views"
        xmlns:misc="clr-namespace:TileBasedLevelEditor.Misc" 
        xmlns:viewmodels="clr-namespace:TileBasedLevelEditor.ViewModels" 
        d:DataContext="{d:DesignInstance Type=viewmodels:TilemapEditorViewModel}"
        mc:Ignorable="d"
        Title="New Tilemap" Height="400" Width="500">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0"
                   Text="New Tilemap"
                   Margin="11 10 0 0"
                   FontSize="20"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"/>
        
        <Border Grid.Row="1"
                CornerRadius="3"
                Background="{StaticResource LightBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="3"
                Margin="10 0 10 10">
            
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Name: "
                               FontSize="16"
                               VerticalAlignment="Center"/>

                    <TextBox Grid.Column="1"
                             Height="30"
                             VerticalAlignment="Center"
                             FontSize="15"
                             VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Left"
                             Text="{Binding NewTilemapName}"/>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="0 10 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="170" MaxWidth="250"/>
                        <ColumnDefinition Width="Auto" MinWidth="170" MaxWidth="250"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0"
                          Grid.IsSharedSizeScope="True">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="TileSizeNameFields"/>
                                <ColumnDefinition Width="Auto" MinWidth="80" SharedSizeGroup="TileSizeFillFields"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                   Text="Tile Width: "
                                   FontSize="16"
                                   VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Height="30"
                                     VerticalAlignment="Center"
                                     FontSize="15"
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Left"
                                     misc:NumericTextBoxBehavior.IsNumericOnly="True"
                                     Text="{Binding NewTilemapTileWidth}"/>
                        </Grid>
                        
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="TileSizeNameFields"/>
                                <ColumnDefinition Width="Auto" MinWidth="80" SharedSizeGroup="TileSizeFillFields"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                   Text="Tile Height: "
                                   FontSize="16"
                                   VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Height="30"
                                     VerticalAlignment="Center"
                                     FontSize="15"
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Left"
                                     misc:NumericTextBoxBehavior.IsNumericOnly="True"
                                     Text="{Binding NewTilemapTileHeight}"/>
                        </Grid>
                    </Grid>

                    <Grid Grid.Column="1"
                          Grid.IsSharedSizeScope="True"
                          Margin="15 0 0 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="TileSizeNameFields"/>
                                <ColumnDefinition Width="Auto" MinWidth="80" SharedSizeGroup="TileSizeFillFields"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                   Text="Tilemap Width: "
                                   FontSize="16"
                                   VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Height="30"
                                     VerticalAlignment="Center"
                                     FontSize="15"
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Left"
                                     misc:NumericTextBoxBehavior.IsNumericOnly="True"
                                     Text="{Binding NewTilemapWidth}"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="TileSizeNameFields"/>
                                <ColumnDefinition Width="Auto" MinWidth="80" SharedSizeGroup="TileSizeFillFields"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                   Text="Tilemap Height: "
                                   FontSize="16"
                                   VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Height="30"
                                     VerticalAlignment="Center"
                                     FontSize="15"
                                     VerticalContentAlignment="Center"
                                     HorizontalContentAlignment="Left"
                                     misc:NumericTextBoxBehavior.IsNumericOnly="True"
                                     Text="{Binding NewTilemapHeight}"/>
                        </Grid>
                    </Grid>
                </Grid>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                                    Content="Save as"
                                    Margin="5 0 0 0"
                                    Command="{Binding AddNewTilemapCommand}"/>

                    <Button Grid.Column="2"
                                    Content="Cancel"
                                    Margin="5 0 0 0"
                                    Command="{Binding CancelNewTilemapCommand}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
