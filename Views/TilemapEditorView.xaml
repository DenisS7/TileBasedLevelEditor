<UserControl x:Class="TileBasedLevelEditor.Views.TilemapEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TileBasedLevelEditor.Views"
             xmlns:viewModels="clr-namespace:TileBasedLevelEditor.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:TilemapEditorViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    FontSize="16"
                    Content="New tilemap"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="10 0 0 0"
                    Command="{Binding CreateNewTilemapCommand}"/>

            <Button Grid.Column="1"
                    FontSize="16"
                    Content="Edit tilemap"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="10 0 0 0"
                    Command="{Binding EditCurrentTilemapCommand}"/>
        </Grid>

        <local:TileGrid Grid.Row="1"
                        DataContext="{Binding TileGridVM}"/>
    </Grid>
</UserControl>
