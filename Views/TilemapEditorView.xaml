<UserControl x:Class="TileBasedLevelEditor.Views.TilemapEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TileBasedLevelEditor.Views"
             xmlns:misc="clr-namespace:TileBasedLevelEditor.Misc"
             xmlns:viewModels="clr-namespace:TileBasedLevelEditor.ViewModels"
             xmlns:converters="clr-namespace:TileBasedLevelEditor.Converters"
             d:DataContext="{d:DesignInstance Type=viewModels:TilemapEditorViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             x:Name="Root">

    <UserControl.Resources>
        <ResourceDictionary>
            <converters:GridTileToPixelConverter x:Key="GridTileToPixelConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    FontSize="16"
                    Content="New tilemap"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="10 0 0 0"
                    Command="{Binding CreateNewTilemapCommand}"/>

            <Button Grid.Column="1"
                    FontSize="16"
                    Content="Edit tilemap"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="10 0 0 0"
                    Command="{Binding EditCurrentTilemapCommand}"/>
        </Grid>

        <local:TileGrid Grid.Row="1"
                        DataContext="{Binding TilemapGridVM}"
                        x:Name="TileGridRoot">
            <misc:TileGridOverlayBehavior.Content>
                <ItemsControl ItemsSource="{Binding PreviewTiles}"
                              IsHitTestVisible="False">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Image}" 
                                   Opacity="0.8"
                                   Width="{Binding DataContext.TileSize.X, ElementName=TileGridRoot}"
                                   Height="{Binding DataContext.TileSize.Y, ElementName=TileGridRoot}"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource GridTileToPixelConverter}">
                                        <Binding Path="Index.X"/>
                                        <Binding Path="DataContext.TileSize.X" RelativeSource="{RelativeSource AncestorType=local:TileGrid}"/>
                                        <Binding Path="DataContext.TileMargin.X" RelativeSource="{RelativeSource AncestorType=local:TileGrid}"/>
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Canvas.Top">
                                <Setter.Value>
                                    <MultiBinding Converter="{StaticResource GridTileToPixelConverter}">
                                        <Binding Path="Index.Y"/>
                                        <Binding Path="DataContext.TileSize.Y" RelativeSource="{RelativeSource AncestorType=local:TileGrid}"/>
                                        <Binding Path="DataContext.TileMargin.Y" RelativeSource="{RelativeSource AncestorType=local:TileGrid}"/>
                                    </MultiBinding>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </misc:TileGridOverlayBehavior.Content>
        </local:TileGrid>
    </Grid>
</UserControl>
